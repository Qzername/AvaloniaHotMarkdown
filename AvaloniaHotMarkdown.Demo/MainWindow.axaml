<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="AvaloniaHotMarkdown.Demo.MainWindow"
		xmlns:HotMarkdown="clr-namespace:AvaloniaHotMarkdown;assembly=AvaloniaHotMarkdown"
        
        xmlns:local="clr-namespace:AvaloniaHotMarkdown.Demo"
        x:DataType="local:MainWindowViewModel"

        Title="AvaloniaHotMarkdown.Demo">
	<Panel>
		<HotMarkdown:HotMarkdownEditor Padding="10"/>
	</Panel>
</Window>